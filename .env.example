# === Ghost Mode OSINT Stack ===
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# === USER IDENTIFIERS ===
EMAIL=your-email@example.com
IP_ADDRESS=192.0.2.1
DOMAIN=example.tld
USERNAME_ALIAS=your-alias
TRACKING_KEYWORDS=keyword1,keyword2

# === SIGNAL CONFIG (optional) ===
SIGNAL_PHONE=+1XXXXXXXXXX
SIGNAL_RECIPIENT=+1XXXXXXXXXX

# === NTFY CONFIG ===
NTFY_SERVER=http://localhost
NTFY_TOPIC=ghostmode-alerts
NTFY_USER=
NTFY_PASS=

# === TAILSCALE CONFIG ===
# Generate at https://login.tailscale.com/admin/settings/keys
# Use ephemeral + preauthorized keys. Rotate regularly.
TS_AUTHKEY=tskey-auth-XXXXXXXXXXXXXXXXXXXX

# === ALERT SETTINGS ===
# Options: print, signal, ntfy, both
ALERT_MODE=print

# === MONITOR SETTINGS ===
SEARXNG_URL=http://localhost:8080
SPIDERFOOT_API=http://localhost:5001
