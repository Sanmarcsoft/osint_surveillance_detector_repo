    {
      "id": 101,
      "type": "row",
      "title": "Response Times",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Response Times",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_duration_seconds{instance=\"https://www.thephenom.app\"}",
          "legendFormat": "www.thephenom.app"
        },
        {
          "refId": "B",
          "expr": "probe_duration_seconds{instance=\"https://drop.thephenom.app\"}",
          "legendFormat": "drop.thephenom.app"
        },
        {
          "refId": "C",
          "expr": "probe_duration_seconds{instance=\"https://nest.thephenom.app\"}",
          "legendFormat": "nest.thephenom.app"
        },
        {
          "refId": "D",
          "expr": "probe_duration_seconds{instance=\"https://chat-testing.thephenom.app\"}",
          "legendFormat": "chat-testing.thephenom.app"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "axisPlacement": "auto",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 5, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 102,
      "type": "row",
      "title": "SSL Certificates",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 6,
      "type": "gauge",
      "title": "SSL: www.thephenom.app",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "(probe_ssl_earliest_cert_expiry{instance=\"https://www.thephenom.app\"} - time()) / 86400",
          "legendFormat": "days"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "min": 0,
          "max": 90,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 14, "color": "yellow" },
              { "value": 30, "color": "green" }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
